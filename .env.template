# Copy this file to `.env` for local development.

USE_LIVE_CLOUD=0

# Cloudflare R2 profile used by prototype live tests.
PPATH_DEV_R2_STORAGE_TYPE=s3
PPATH_DEV_R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
PPATH_DEV_R2_ACCESS_KEY_ID=<access-key-id>
PPATH_DEV_R2_SECRET_ACCESS_KEY=<secret-access-key>
PPATH_DEV_R2_REGION=auto
PPATH_DEV_R2_ROOT=s3://<bucket-name>

# Optional local cache settings for remote reads.
# The effective cache path becomes <CACHE_DIR>/PPATH_DEV_R2/
PPATH_DEV_R2_CACHE_DIR=/tmp/ppath-cache
PPATH_DEV_R2_CACHE_MODE=persistent
